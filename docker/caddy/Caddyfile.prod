ats.propium.co {
  @mcp_api {
    path /mcp
    path /mcp/*
  }
  handle @mcp_api {
    reverse_proxy api:3001
  }

  handle /oauth/* {
    reverse_proxy api:3001
  }

  handle /.well-known/oauth-authorization-server {
    reverse_proxy api:3001
  }

  handle /.well-known/oauth-protected-resource {
    reverse_proxy api:3001
  }

  handle /api/* {
    reverse_proxy api:3001
  }

  handle {
    reverse_proxy web:80
  }
}
