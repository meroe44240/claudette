{
  "name": "humanup-ats",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:e2e": "turbo test:e2e",
    "db:migrate": "pnpm --filter @humanup/api db:migrate",
    "db:seed": "pnpm --filter @humanup/api db:seed",
    "db:reset": "pnpm --filter @humanup/api db:reset",
    "db:generate": "pnpm --filter @humanup/api db:generate"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  }
}
