model AiPendingValidation {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  user              User      @relation("AiPendingValidationUser", fields: [userId], references: [id])
  sourceType        String    @db.VarChar(20) // call, meeting, email
  activiteId        String?   @db.Uuid
  entiteType        String?   @db.VarChar(50)
  entiteId          String?   @db.Uuid
  analysisJson      Json
  proposedUpdates   Json?
  proposedTasks     Json?
  status            String    @default("pending") @db.VarChar(20) // pending, validated, modified, dismissed
  validatedAt       DateTime? @db.Timestamptz()
  modificationsJson Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz()

  @@index([userId, status])
  @@map("ai_pending_validations")
