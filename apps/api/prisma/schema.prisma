// ─── BOOKING SYSTEM (Calendly-like) ─────────────────

model BookingSetting {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  user            User     @relation("BookingSettingUser", fields: [userId], references: [id])
  slug            String   @unique @db.VarChar(100)
  isActive        Boolean  @default(true)
  workingDays     Int[]    @default([1, 2, 3, 4, 5])
  startTime       String   @default("09:00") @db.VarChar(5)
  endTime         String   @default("18:00") @db.VarChar(5)
  slotDuration    Int      @default(30)
  bufferMinutes   Int      @default(15)
  minNoticeHours  Int      @default(2)
  maxAdvanceDays  Int      @default(30)
  welcomeMessage  String?  @db.Text
  reminderEmail   Boolean  @default(true)
  reminderBefore  Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  bookingTypes    BookingType[]

  @@map("booking_settings")
}

model BookingType {
  id              String   @id @default(uuid()) @db.Uuid
  settingId       String   @db.Uuid
  setting         BookingSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  slug            String   @db.VarChar(100)
  label           String   @db.VarChar(100)
  durationMinutes Int
  targetType      String   @db.VarChar(20) // 'candidate' or 'client'
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  @@unique([settingId, slug])
  @@map("booking_types")
}

model Booking {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  user                User      @relation("BookingUser", fields: [userId], references: [id])
  mandatId            String?   @db.Uuid
  mandat              Mandat?   @relation("BookingMandat", fields: [mandatId], references: [id])
  entityType          String    @db.VarChar(20)
  candidatId          String?   @db.Uuid
  candidat            Candidat? @relation("BookingCandidat", fields: [candidatId], references: [id])
  clientId            String?   @db.Uuid
  client              Client?   @relation("BookingClient", fields: [clientId], references: [id])
  firstName           String    @db.VarChar(100)
  lastName            String    @db.VarChar(100)
  email               String    @db.VarChar(255)
  phone               String    @db.VarChar(50)
  salary              String?   @db.VarChar(50)
  currentCompany      String?   @db.VarChar(255)
  availability        String?   @db.VarChar(50)
  competingProcesses  String?   @db.VarChar(50)
  message             String?   @db.Text
  bookingDate         DateTime  @db.Date
  bookingTime         String    @db.VarChar(5)
  durationMinutes     Int       @default(30)
  calendarEventId     String?   @db.VarChar(255)
  status              String    @default("confirmed") @db.VarChar(20)
  cancelToken         String?   @unique @db.VarChar(64)
  cancelledAt         DateTime? @db.Timestamptz()
  cancelReason        String?   @db.Text
  createdAt           DateTime  @default(now()) @db.Timestamptz()
  reminders           BookingReminder[]

  @@index([userId])
  @@index([email])
  @@index([bookingDate])
  @@index([status])
  @@map("bookings")
}

model BookingReminder {
  id           String    @id @default(uuid()) @db.Uuid
  bookingId    String    @db.Uuid
  booking      Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type         String    @db.VarChar(30)
  status       String    @default("pending") @db.VarChar(20)
  scheduledAt  DateTime  @db.Timestamptz()
  sentAt       DateTime? @db.Timestamptz()
  errorMessage String?   @db.Text
  createdAt    DateTime  @default(now()) @db.Timestamptz()

  @@index([status, scheduledAt])
  @@map("booking_reminders")
}

