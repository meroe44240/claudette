generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS ───────────────────────────────────────────

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique @db.VarChar(255)
  passwordHash       String    @db.VarChar(255)
  nom                String    @db.VarChar(255)
  prenom             String?   @db.VarChar(255)
  avatarUrl          String?   @db.VarChar(500)
  role               Role      @default(RECRUTEUR)
  mustChangePassword Boolean   @default(true)
  apiKey             String?   @unique @db.VarChar(255)
  lastLoginAt        DateTime? @db.Timestamptz()
  // Compensation (admin-only)
  monthlySalary      Float?    // Coût mensuel chargé (salaire brut + charges)
  variableRate       Float?    // Commission % sur les fees placés
  startDate          DateTime? @db.Timestamptz() // Date de début pour prorata
  calendlyUrl        String?   @db.VarChar(500)
  slackUserId        String?   @db.VarChar(30) // Slack user id (e.g. U0123ABC) for DMs
  fonction             Fonction @default(RECRUTEUR)
  excludeFromTeamStats Boolean  @default(false)
  createdAt          DateTime  @default(now()) @db.Timestamptz()
  updatedAt          DateTime  @updatedAt @db.Timestamptz()

  candidatsCreated    Candidat[]     @relation("CandidatCreatedBy")
  clientsCreated      Client[]       @relation("ClientCreatedBy")
  entreprisesCreated  Entreprise[]   @relation("EntrepriseCreatedBy")
  mandatsCreated      Mandat[]       @relation("MandatCreatedBy")
  candidaturesCreated Candidature[]  @relation("CandidatureCreatedBy")
  activites           Activite[]     @relation("ActiviteUser")
  assignedCandidats   Candidat[]     @relation("CandidatAssignedTo")
  assignedClients     Client[]       @relation("ClientAssignedTo")
  assignedMandats     Mandat[]       @relation("MandatAssignedTo")
  sourcedMandats      Mandat[]       @relation("MandatSourceur")
  salesMandats        Mandat[]       @relation("MandatSales")
  recruteurMandats    Mandat[]       @relation("MandatRecruteur")
  auditLogs           AuditLog[]     @relation("AuditLogUser")
  reminders           Reminder[]     @relation("ReminderUser")
  calendarSuggestions AiCalendarSuggestion[] @relation("CalendarSuggestionUser")
  pipelineSuggestions AiPipelineSuggestion[] @relation("PipelineSuggestionUser")
  onboardingCompleted  Boolean   @default(false)
  mcpActionLogs        McpActionLog[]          @relation("McpActionLogUser")
  recruiterObjectives  RecruiterObjective[]    @relation("RecruiterObjectiveUser")
  aiPendingValidations AiPendingValidation[]   @relation("AiPendingValidationUser")

  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  RECRUTEUR
}

// Fonction (metier) — distincte de Role (permission).
// Un user peut etre SALES (chasse le mandat cote client), RECRUTEUR (source les
// candidats), ou LES_DEUX (Meroe par exemple).
enum Fonction {
  SALES
  RECRUTEUR
  LES_DEUX
}

// ─── ENTREPRISES ─────────────────────────────────────

model Entreprise {
  id           String            @id @default(uuid()) @db.Uuid
  nom          String            @db.VarChar(255)
  secteur      String?           @db.VarChar(100)
  siteWeb      String?           @db.VarChar(500)
  domaine      String?           @db.VarChar(255)
  taille       TailleEntreprise?
  localisation String?           @db.VarChar(255)
  linkedinUrl  String?           @db.VarChar(500)
  logoUrl      String?           @db.VarChar(1000)
  notes        String?           @db.Text
  // Pappers (données légales françaises)
  siren             String?           @db.VarChar(9)
  siret             String?           @db.VarChar(14)
  formeJuridique    String?           @db.VarChar(100)
  capitalSocial     Float?
  chiffreAffaires   Float?
  effectif          String?           @db.VarChar(50)
  dateCreation      String?           @db.VarChar(10)
  codeNAF           String?           @db.VarChar(10)
  libelleNAF        String?           @db.VarChar(255)
  adresseComplete   String?           @db.VarChar(500)
  pappersUrl        String?           @db.VarChar(500)
  pappersEnrichedAt DateTime?         @db.Timestamptz()
  pappersRawData    Json?
  createdById  String?           @db.Uuid
  createdBy    User?             @relation("EntrepriseCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime          @default(now()) @db.Timestamptz()
  updatedAt    DateTime          @updatedAt @db.Timestamptz()

  clients Client[]
  mandats Mandat[]

  @@map("entreprises")
}

enum TailleEntreprise {
  STARTUP
  PME
  ETI
  GRAND_GROUPE
}

// ─── CLIENTS (contacts côté entreprise) ──────────────

model Client {
  id           String       @id @default(uuid()) @db.Uuid
  nom          String       @db.VarChar(255)
  prenom       String?      @db.VarChar(255)
  email        String?      @db.VarChar(255)
  telephone    String?      @db.VarChar(50)
  poste        String?      @db.VarChar(255)
  roleContact  RoleContact?
  linkedinUrl  String?      @db.VarChar(500)
  entrepriseId String       @db.Uuid
  entreprise   Entreprise   @relation(fields: [entrepriseId], references: [id])
  statutClient StatutClient @default(LEAD)
  typeClient   TypeClient   @default(INBOUND)
  notes        String?      @db.Text
  createdById  String?      @db.Uuid
  createdBy    User?        @relation("ClientCreatedBy", fields: [createdById], references: [id])
  assignedToId String?      @db.Uuid
  assignedTo   User?        @relation("ClientAssignedTo", fields: [assignedToId], references: [id])
  createdAt    DateTime     @default(now()) @db.Timestamptz()
  updatedAt    DateTime     @updatedAt @db.Timestamptz()

  mandats Mandat[]

  @@map("clients")
}

enum RoleContact {
  HIRING_MANAGER
  DRH
  PROCUREMENT
  CEO
  AUTRE
}

enum StatutClient {
  LEAD
  PREMIER_CONTACT
  BESOIN_QUALIFIE
  PROPOSITION_ENVOYEE
  MANDAT_SIGNE
  RECURRENT
  INACTIF
}

enum TypeClient {
  INBOUND
  OUTBOUND
  RESEAU
  CLIENT_ACTIF
  RECURRENT
}

// ─── CANDIDATS ───────────────────────────────────────

model Candidat {
  id                 String    @id @default(uuid()) @db.Uuid
  nom                String    @db.VarChar(255)
  prenom             String?   @db.VarChar(255)
  email              String?   @db.VarChar(255)
  telephone          String?   @db.VarChar(50)
  linkedinUrl        String?   @db.VarChar(500)
  photoUrl           String?   @db.VarChar(1000)
  cvUrl              String?   @db.VarChar(500)
  cvTexte            String?   @db.Text
  posteActuel        String?   @db.VarChar(255)
  entrepriseActuelle String?   @db.VarChar(255)
  localisation       String?   @db.VarChar(255)
  salaireActuel      Int?
  salaireSouhaite    Int?
  anneesExperience   Int?
  disponibilite      String?   @db.VarChar(100)
  mobilite           String?   @db.VarChar(255)
  source             String?   @db.VarChar(100)
  tags               String[]  @default([])
  notes              String?   @db.Text
  consentementRgpd   Boolean   @default(false)
  consentementDate   DateTime? @db.Timestamptz()
  // AI-generated fields
  aiPitchShort        String?   @db.VarChar(500)
  aiPitchLong         String?   @db.Text
  aiSellingPoints     Json?     // string[] - key selling points
  aiIdealFor          String?   @db.Text
  aiAnonymizedProfile Json?     // { titre, summary, bulletPoints }
  aiParsedAt          DateTime? @db.Timestamptz()
  createdById        String?   @db.Uuid
  createdBy          User?     @relation("CandidatCreatedBy", fields: [createdById], references: [id])
  assignedToId       String?   @db.Uuid
  assignedTo         User?     @relation("CandidatAssignedTo", fields: [assignedToId], references: [id])
  createdAt          DateTime  @default(now()) @db.Timestamptz()
  updatedAt          DateTime  @updatedAt @db.Timestamptz()

  candidatures Candidature[]
  experiences  CandidatExperience[]

  @@map("candidats")
}

// ─── EXPERIENCES CANDIDAT ────────────────────────────

model CandidatExperience {
  id           String   @id @default(uuid()) @db.Uuid
  candidatId   String   @db.Uuid
  candidat     Candidat @relation(fields: [candidatId], references: [id], onDelete: Cascade)
  titre        String   @db.VarChar(255)
  entreprise   String   @db.VarChar(255)
  anneeDebut   Int
  anneeFin     Int?
  highlights   String[] @default([])
  source       String   @default("cv") @db.VarChar(20)
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()

  @@index([candidatId])
  @@index([titre])
  @@index([entreprise])
  @@map("candidat_experiences")
}

// ─── MANDATS ─────────────────────────────────────────

model Mandat {
  id               String       @id @default(uuid()) @db.Uuid
  titrePoste       String       @db.VarChar(255)
  entrepriseId     String       @db.Uuid
  entreprise       Entreprise   @relation(fields: [entrepriseId], references: [id])
  clientId         String       @db.Uuid
  client           Client       @relation(fields: [clientId], references: [id])
  description      String?      @db.Text
  localisation     String?      @db.VarChar(255)
  salaireMin       Int?
  salaireMax       Int?
  feePourcentage   Decimal      @default(20.00) @db.Decimal(5, 2)
  feeMontantEstime Int?
  feeMontantFacture Int?
  feeStatut        FeeStatut    @default(NON_FACTURE)
  statut           StatutMandat @default(OUVERT)
  priorite         Priorite     @default(NORMALE)
  dateOuverture    DateTime     @default(now()) @db.Date
  dateCloture      DateTime?    @db.Date
  notes            String?      @db.Text
  slug             String?      @unique @db.VarChar(255)
  salaryRange      String?      @db.VarChar(255)
  pitchPoints      Json?
  isBookingPublic  Boolean      @default(true)
  createdById      String?      @db.Uuid
  createdBy        User?        @relation("MandatCreatedBy", fields: [createdById], references: [id])
  assignedToId     String?      @db.Uuid
  assignedTo       User?        @relation("MandatAssignedTo", fields: [assignedToId], references: [id])
  sourceurId       String?      @db.Uuid
  sourceur         User?        @relation("MandatSourceur", fields: [sourceurId], references: [id])
  // Binome : Sales chasse le mandat cote client, Recruteur source les candidats.
  // Backfill : salesId = assignedToId, recruteurId = sourceurId.
  // assignedTo/sourceur restent pour compat mais salesId/recruteurId sont la
  // source de verite pour le recap et les futures attributions CA/prime.
  salesId          String?      @db.Uuid
  sales            User?        @relation("MandatSales", fields: [salesId], references: [id])
  recruteurId      String?      @db.Uuid
  recruteur        User?        @relation("MandatRecruteur", fields: [recruteurId], references: [id])
  transcript           String?      @db.Text
  ficheDePoste         String?      @db.Text
  scorecard            Json?
  scorecardGeneratedAt DateTime?    @db.Timestamptz()
  sourceLead       String?      @db.VarChar(255)
  // Stages visibles côté client via le portail (chantier 3) et le bouton
  // "Aperçu client" du kanban. Par défaut : les étapes où le client a du
  // contexte à voir (envoyés, entretien client, offre, placé).
  visibleStages    StageCandidature[] @default([ENVOYE_CLIENT, ENTRETIEN_CLIENT, OFFRE, PLACE])
  // Contrat mandat (envoi signature). Placeholder tant qu'aucun provider
  // (DocuSign/Yousign) n'est branché — trace en base seulement.
  contractStatus   ContractStatus @default(DRAFT)
  contractSentAt   DateTime?    @db.Timestamptz()
  contractSignedAt DateTime?    @db.Timestamptz()
  paymentTerms     String?      @db.VarChar(50)     // "reception", "30j", "45j_fdm", "60j", "signature"
  applicableCountry String?     @db.VarChar(2)      // ISO-3166-1 alpha-2 (FR, GB, HK…)
  createdAt        DateTime     @default(now()) @db.Timestamptz()
  updatedAt        DateTime     @updatedAt @db.Timestamptz()

  candidatures        Candidature[]
  pipelineSuggestions AiPipelineSuggestion[] @relation("PipelineSuggestionMandat")
  contractApprovals   ContractApproval[]

  @@map("mandats")
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
}

// Demande de validation admin quand un contrat propose un feePourcentage
// sous le plancher (18%). Bloque l'envoi tant qu'un admin n'a pas approuvé.
model ContractApproval {
  id             String                 @id @default(uuid()) @db.Uuid
  mandatId       String                 @db.Uuid
  mandat         Mandat                 @relation(fields: [mandatId], references: [id], onDelete: Cascade)
  requestedById  String                 @db.Uuid
  feeRequested   Decimal                @db.Decimal(5, 2)  // ex: 15.00 (%)
  reason         String                 @db.Text
  status         ContractApprovalStatus @default(PENDING)
  approvedById   String?                @db.Uuid
  approvedAt     DateTime?              @db.Timestamptz()
  rejectionNote  String?                @db.Text
  createdAt      DateTime               @default(now()) @db.Timestamptz()
  updatedAt      DateTime               @updatedAt @db.Timestamptz()

  @@index([mandatId])
  @@index([status])
  @@map("contract_approvals")
}

enum ContractApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FeeStatut {
  NON_FACTURE
  FACTURE
  PAYE
}

enum StatutMandat {
  OUVERT
  EN_COURS
  GAGNE
  PERDU
  ANNULE
  CLOTURE
}

enum Priorite {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

// ─── CANDIDATURES (pivot mandat <-> candidat) ────────

model Candidature {
  id                  String           @id @default(uuid()) @db.Uuid
  mandatId            String           @db.Uuid
  mandat              Mandat           @relation(fields: [mandatId], references: [id])
  candidatId          String           @db.Uuid
  candidat            Candidat         @relation(fields: [candidatId], references: [id])
  stage               StageCandidature @default(SOURCING)
  notes               String?          @db.Text
  datePresentation    DateTime?        @db.Timestamptz()
  dateEntretienClient DateTime?        @db.Timestamptz()
  dateDemarrage       DateTime?        @db.Date
  sourcePlacement     String?          @db.VarChar(255)
  motifRefus          MotifRefus?
  motifRefusDetail    String?          @db.Text
  createdById         String?          @db.Uuid
  createdBy           User?            @relation("CandidatureCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime         @default(now()) @db.Timestamptz()
  updatedAt           DateTime         @updatedAt @db.Timestamptz()

  stageHistory        StageHistory[]
  pipelineSuggestions AiPipelineSuggestion[] @relation("PipelineSuggestionCandidature")

  @@unique([mandatId, candidatId])
  @@map("candidatures")
}

enum StageCandidature {
  SOURCING
  CONTACTE
  ENTRETIEN_1
  ENVOYE_CLIENT
  ENTRETIEN_CLIENT
  OFFRE
  PLACE
  REFUSE
}

enum MotifRefus {
  SALAIRE
  PROFIL_PAS_ALIGNE
  CANDIDAT_DECLINE
  CLIENT_REFUSE
  TIMING
  POSTE_POURVU
  AUTRE
}

// ─── HISTORIQUE DES STAGES ───────────────────────────

model StageHistory {
  id            String            @id @default(uuid()) @db.Uuid
  candidatureId String            @db.Uuid
  candidature   Candidature       @relation(fields: [candidatureId], references: [id], onDelete: Cascade)
  fromStage     StageCandidature?
  toStage       StageCandidature
  changedById   String?           @db.Uuid
  changedAt     DateTime          @default(now()) @db.Timestamptz()

  @@index([candidatureId])
  @@map("stage_history")
}

// ─── ACTIVITÉS (journal polymorphe) ──────────────────

model Activite {
  id             String         @id @default(uuid()) @db.Uuid
  type           TypeActivite
  direction      Direction?
  entiteType     EntiteType?
  entiteId       String?        @db.Uuid
  userId         String?        @db.Uuid
  user           User?          @relation("ActiviteUser", fields: [userId], references: [id])
  titre          String?        @db.VarChar(500)
  contenu        String?        @db.Text
  metadata       Json           @default("{}")
  source         SourceActivite @default(MANUEL)
  bookmarked     Boolean        @default(false)
  isTache        Boolean        @default(false)
  tacheCompleted Boolean        @default(false)
  tacheDueDate   DateTime?      @db.Timestamptz()
  createdAt      DateTime       @default(now()) @db.Timestamptz()
  updatedAt      DateTime       @updatedAt @db.Timestamptz()

  fichiers FichierActivite[]

  @@index([entiteType, entiteId])
  @@index([bookmarked])
  @@index([isTache, tacheCompleted, tacheDueDate])
  @@map("activites")
}

enum TypeActivite {
  APPEL
  EMAIL
  MEETING
  NOTE
  TACHE
  TRANSCRIPT
}

enum Direction {
  ENTRANT
  SORTANT
}

enum EntiteType {
  CANDIDAT
  CLIENT
  ENTREPRISE
  MANDAT
}

enum SourceActivite {
  MANUEL
  ALLO
  GMAIL
  CALENDAR
  GOOGLE_DOCS
  AGENT_IA
  SYSTEME
}

// ─── FICHIERS JOINTS AUX ACTIVITÉS ──────────────────

model FichierActivite {
  id         String   @id @default(uuid()) @db.Uuid
  activiteId String   @db.Uuid
  activite   Activite @relation(fields: [activiteId], references: [id], onDelete: Cascade)
  nom        String   @db.VarChar(255)
  url        String   @db.VarChar(500)
  mimeType   String?  @db.VarChar(100)
  taille     Int?
  createdAt  DateTime @default(now()) @db.Timestamptz()

  @@map("fichiers_activites")
}

// ─── NOTIFICATIONS ───────────────────────────────────

// ─── TEMPLATES ───────────────────────────────────────

// ─── INTEGRATION CONFIG ────────────────────────────
model IntegrationConfig {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  provider     String   @db.VarChar(50)  // 'allo', 'gmail', 'calendar'
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  tokenExpiry  DateTime? @db.Timestamptz()
  config       Json     @default("{}")    // extra config (drive folder id, etc.)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()

  @@unique([userId, provider])
  @@map("integration_configs")
}

// ─── SÉQUENCES (WORKFLOWS AUTOMATIQUES) ────────────

// ─── SDR MANAGER (LISTES DE PROSPECTION) ────────────

// ─── ADCHASE (PUSH CANDIDAT → PROSPECTS) ────────────

// ─── AUDIT LOG (Historique des modifications) ────────────

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation("AuditLogUser", fields: [userId], references: [id])
  action      String   @db.VarChar(20) // CREATE, UPDATE, DELETE
  entityType  String   @db.VarChar(50) // CANDIDAT, CLIENT, ENTREPRISE, MANDAT, etc.
  entityId    String   @db.Uuid
  entityLabel String?  @db.VarChar(500) // "Jean Dupont" for display
  changes     Json?    // { field: { old: value, new: value } }
  metadata    Json?
  createdAt   DateTime @default(now()) @db.Timestamptz()

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── REMINDERS (Rappels automatiques) ────────────────────

model Reminder {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  user        User      @relation("ReminderUser", fields: [userId], references: [id])
  type        String    @db.VarChar(50) // MANDAT_DORMANT, TACHE_RETARD, RELANCE_CLIENT, CUSTOM
  entityType  String?   @db.VarChar(50)
  entityId    String?   @db.Uuid
  titre       String    @db.VarChar(500)
  description String?   @db.Text
  triggerAt   DateTime  @db.Timestamptz()
  fired       Boolean   @default(false)
  firedAt     DateTime? @db.Timestamptz()
  createdAt   DateTime  @default(now()) @db.Timestamptz()

  @@index([userId, fired])
  @@index([triggerAt])
  @@map("reminders")
}

// ─── AI USAGE LOGS ─────────────────────────────────

model AiUsageLog {
  id           String   @id @default(uuid()) @db.Uuid
  feature      String   @db.VarChar(50)  // cv_parsing, call_summary, call_brief, prospect_detection
  model        String   @db.VarChar(100) // claude-haiku-4-5-20251001, claude-sonnet-4-5-20250929
  userId       String   @db.Uuid
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0)
  durationMs   Int      @default(0)
  success      Boolean  @default(true)
  error        String?  @db.Text
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @db.Timestamptz()

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

// ─── AI CALL SUMMARIES (Résumés post-call) ─────────

model AiCallSummary {
  id              String   @id @default(uuid()) @db.Uuid
  activiteId      String   @unique @db.Uuid
  entityType      String   @db.VarChar(20)  // CANDIDAT, CLIENT
  entityId        String   @db.Uuid
  userId          String   @db.Uuid
  summaryJson     Json     @default("{}")  // Full Claude response
  actionsAccepted Json     @default("[]") // IDs of accepted action items
  updatesApplied  Json     @default("[]") // IDs of applied info updates
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  @@index([activiteId])
  @@index([userId])
  @@map("ai_call_summaries")
}

// ─── AI CALL BRIEFS (Briefs pré-call enrichis) ─────

model AiCallBrief {
  id              String   @id @default(uuid()) @db.Uuid
  entityType      String   @db.VarChar(20)  // CANDIDAT, CLIENT
  entityId        String   @db.Uuid
  calendarEventId String?  @db.VarChar(255)
  userId          String   @db.Uuid
  briefJson       Json     @default("{}")  // Structured brief content
  webResultsRaw   Json?                    // Raw web search results for audit
  generatedAt     DateTime @default(now()) @db.Timestamptz()
  expiresAt       DateTime @db.Timestamptz() // 24h cache

  @@index([entityType, entityId])
  @@index([expiresAt])
  @@map("ai_call_briefs")
}

// ─── AI PROSPECT SEARCHES (Détection signaux faibles) ─

model AiProspectSearch {
  id               String   @id @default(uuid()) @db.Uuid
  candidatId       String   @db.Uuid
  campaignId       String?  @db.Uuid
  userId           String   @db.Uuid
  searchParams     Json     @default("{}")  // { sectors, locations, companySize, signalTypes }
  resultsJson      Json     @default("[]") // Full results array
  prospectsSelected Json    @default("[]") // Selected prospects
  resultCount      Int      @default(0)
  createdAt        DateTime @default(now()) @db.Timestamptz()
  expiresAt        DateTime @db.Timestamptz() // 48h cache

  @@index([candidatId])
  @@index([expiresAt])
  @@map("ai_prospect_searches")
}

// ─── AI CALENDAR SUGGESTIONS ─────────────────────

model AiCalendarSuggestion {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  calendarEventId String    @db.VarChar(255)
  eventTitle      String    @db.VarChar(500)
  eventDate       DateTime  @db.Timestamptz()
  suggestionType  String    @db.VarChar(20) // 'candidate', 'client', 'company'
  suggestedData   Json      @db.JsonB
  confidence      Float
  reasoning       String?   @db.Text
  status          String    @default("pending") @db.VarChar(20) // 'pending', 'accepted', 'dismissed'
  createdEntityId String?   @db.Uuid
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  resolvedAt      DateTime? @db.Timestamptz()

  user            User      @relation("CalendarSuggestionUser", fields: [userId], references: [id])

  @@index([userId, status])
  @@index([calendarEventId])
  @@map("ai_calendar_suggestions")
}

// ─── AI PIPELINE SUGGESTIONS ─────────────────────

model AiPipelineSuggestion {
  id              String   @id @default(uuid()) @db.Uuid
  candidatureId   String   @db.Uuid
  mandatId        String   @db.Uuid
  userId          String   @db.Uuid
  currentStage    String   @db.VarChar(50)
  suggestedStage  String   @db.VarChar(50)
  confidence      Float
  reasoning       String?  @db.Text
  triggerType     String   @db.VarChar(50) // 'calendar_event', 'email', 'call', 'inactivity'
  triggerData     Json?    @db.JsonB
  status          String   @default("pending") @db.VarChar(20)
  appliedStage    String?  @db.VarChar(50)
  createdAt       DateTime @default(now()) @db.Timestamptz()
  resolvedAt      DateTime? @db.Timestamptz()

  candidature     Candidature @relation("PipelineSuggestionCandidature", fields: [candidatureId], references: [id])
  mandat          Mandat      @relation("PipelineSuggestionMandat", fields: [mandatId], references: [id])
  user            User        @relation("PipelineSuggestionUser", fields: [userId], references: [id])

  @@index([userId, status])
  @@index([candidatureId])
  @@map("ai_pipeline_suggestions")
}

