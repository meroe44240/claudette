# Database
DATABASE_URL=postgresql://humanup:humanup_dev@localhost:5432/humanup_dev
DATABASE_URL_TEST=postgresql://humanup:humanup_dev@localhost:5432/humanup_test

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# SMTP (for password reset emails)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=your-resend-api-key
SMTP_FROM=noreply@humanup.io

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/integrations/gmail/callback

# Allo VoIP
ALLO_API_KEY=
ALLO_BASE_URL=https://api.withallo.com
ALLO_WEBHOOK_SECRET=

# Anthropic (for transcript parsing)
ANTHROPIC_API_KEY=

# App
API_PORT=3001
WEB_PORT=5173
NODE_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
