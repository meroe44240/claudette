# Database
DATABASE_URL=postgresql://humanup:humanup_dev@localhost:5432/humanup_dev
DATABASE_URL_TEST=postgresql://humanup:humanup_dev@localhost:5432/humanup_test

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# SMTP (for password reset emails only — Gmail API is used for the rest)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=your-resend-api-key
SMTP_FROM=noreply@humanup.io

# Google OAuth (Gmail + Calendar + Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/integrations/gmail/callback

# Allo VoIP (calls + transcripts)
ALLO_API_KEY=
ALLO_BASE_URL=https://api.withallo.com
ALLO_WEBHOOK_SECRET=

# AI providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PRIMARY_LLM_PROVIDER=gemini

# Pappers (French legal / SIREN enrichment for entreprises)
PAPPERS_API_KEY=
PAPPERS_BASE_URL=https://api.pappers.fr/v2

# FullEnrich (contact enrichment — email/phone)
FULLENRICH_API_KEY=

# Kalent (shared team sourcing — https://docs.kalent.ai)
KALENT_API_KEY=

# Slack (daily report webhook + Bot DMs on close-won, alerts, etc.)
SLACK_WEBHOOK_URL=
SLACK_SEND_TIME=09:00
SLACK_BOT_TOKEN=
SLACK_BOT_ICON_URL=

# MCP (public URL of the ATS for the MCP server metadata)
MCP_PUBLIC_URL=

# App
API_PORT=3001
WEB_PORT=5173
NODE_ENV=development
TZ=Europe/Paris
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
